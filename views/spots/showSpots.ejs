<% layout("/layouts/sk8tt.ejs")%>

<div class="container mt-4 pb-5">
    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <img src="<%= spot.image %>" class="card-img-top rounded-top" alt="<%= spot.title %>" style="max-height: 400px; object-fit: cover;">
                <div class="card-body p-4">
                    <h1 class="card-title fw-bold display-6"><%= spot.title %></h1>
                    <h5 class="text-muted mb-3"><i class="bi bi-geo-alt"></i> <%= spot.location %></h5>
                    <p class="card-text lead text-secondary"><%= spot.description %></p>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex gap-2">
                        <a class="btn btn-info text-white px-4" href="/spots/<%=spot._id%>/edit">Edit Spot</a>
                        <form action="/spots/<%=spot._id%>?_method=DELETE" method="post">
                            <button class="btn btn-outline-danger px-4">Delete Spot</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ps-lg-4">
                
                <div class="card shadow-sm border-0 mb-5">
                    <div class="card-body p-4">
                        <h4 class="card-title mb-3 text-uppercase fw-bold">Leave a Review</h4>
                        <form class="validated-form" action="/spots/<%=spot._id%>/reviews" method="post" novalidate>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Rating</label>
                                <div class="star-rating d-flex flex-row-reverse justify-content-end gap-1">
                                    <input type="radio" id="star5" name="review[stars]" value="5" />
                                    <label for="star5" class="fs-2">★</label>
                                    <input type="radio" id="star4" name="review[stars]" value="4" />
                                    <label for="star4" class="fs-2">★</label>
                                    <input type="radio" id="star3" name="review[stars]" value="3" />
                                    <label for="star3" class="fs-2">★</label>
                                    <input type="radio" id="star2" name="review[stars]" value="2" />
                                    <label for="star2" class="fs-2">★</label>
                                    <input type="radio" id="star1" name="review[stars]" value="1" required />
                                    <label for="star1" class="fs-2">★</label>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold" for="body">Your Thoughts</label>
                                <textarea class="form-control" name="review[body]" id="body" rows="3" placeholder="How was the session?" required></textarea>
                            </div>
                            <button class="btn btn-success w-100 py-2 fw-bold text-uppercase">Submit Review</button>
                        </form>
                    </div>
                </div>

                <h4 class="fw-bold mb-3 text-uppercase">Community Feedback</h4>
                <div class="reviews-list">
                    <% if (spot.reviews.length === 0) { %>
                        <div class="alert alert-dark text-center border-dashed py-4 bg-transparent">
                            <p class="text-muted mb-0">No reviews yet. Be the first to drop some knowledge!</p>
                        </div>
                    <% } %>

                    <% for(let review of spot.reviews) { %>
                        <div class="card mb-3 border-0 shadow-sm bg-dark-subtle">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="mb-1">
                                            <% for(let i=1; i <=5; i++) { %>
                                                <span class="<%= i <= review.stars ? 'text-warning' : 'text-muted' %> fs-6">★</span>
                                            <% } %>
                                        </div>
                                        <p class="card-text mb-0"><%= review.body %></p>
                                    </div>
                                    <form action="/spots/<%= spot._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                        <button class="btn btn-sm text-danger border-0 p-0" title="Delete Review">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .star-rating input { display: none; }
    .star-rating label { color: #444; cursor: pointer; transition: color 0.2s; margin-bottom: 0; }
    .star-rating input:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label { color: #ffc107; }
    
    .border-dashed { border: 2px dashed #444 !important; }
    
    /* Ensure cards stay dark in your blackout theme */
    [data-bs-theme="dark"] .bg-dark-subtle {
        background-color: #111 !important;
    }
</style>