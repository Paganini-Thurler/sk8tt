<% layout("/layouts/sk8tt.ejs")%>
<h1 class="text-center">Skate or die</h1>
<div class="mb-3">
    <a class="btn btn-primary" href="/spots/new">Add a spot</a>
</div>
<% for (let spot of spots) {%>
    <div class="card mb-3">
        <div class="row">
            <div class="col-md-4">
                <img class="img-fluid" src="<%=spot.image%>">
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h4 class="card-title">
                        <%=spot.title%>
                    </h4>
                    <p class="card-text">
                        <%=spot.location%>
                    </p>
                    <a class="btn btn-primary" href="/spots/<%=spot._id%>"> view</a>
                </div>

            </div>

        </div>

    </div>
<%}%>